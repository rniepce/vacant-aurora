{
    "manifest_version": 3,
    "name": "Amazon Price Monitor (iOS)",
    "version": "1.0",
    "description": "Monitors price drops in your Amazon.com.br shopping cart.",
    "permissions": [
        "alarms",
        "storage",
        "notifications",
        "offscreen"
    ],
    "host_permissions": [
        "https://www.amazon.com.br/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Amazon Price Monitor"
    },
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}