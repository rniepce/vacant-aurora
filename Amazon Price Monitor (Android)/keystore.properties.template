# Copy this file to "keystore.properties" and fill in your real values.
# keystore.properties is git-ignored — NEVER commit it or your .jks file.
#
# Create the keystore once with:
#   keytool -genkey -v -keystore radar-precos-release.jks \
#       -keyalg RSA -keysize 2048 -validity 10000 -alias radarprecos
#
storeFile=../radar-precos-release.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=radarprecos
keyPassword=YOUR_KEY_PASSWORD
