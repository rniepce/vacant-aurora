<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The app does not track users and shows no third-party ads. -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- No domains used for tracking. -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- All cart/price data stays on device and is never sent to the developer
	     or any third party, so no data types are collected. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required-reason APIs. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- The app reads/writes its own saved price history via UserDefaults. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
